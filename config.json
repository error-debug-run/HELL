{
  "hell": {
    "version": "0.1.0",
    "os": "windows",
    "log_level": "info",
    "python_path": "D:\\HELL\\.venv\\Scripts\\python.exe",
    "hell_root": "D:\\HELL"
  },

  "stt": {
    "wake_word"           : "bring it on",
    "sleep_word"          : "go to sleep",
    "model_size"          : "small",
    "model_path"          : "models/whisper-small",
    "device"              : "cuda",
    "sample_rate"         : 16000,
    "window_size"         : 5,
    "slide_every"         : 2.5,
    "energy_threshold"    : 0.005,
    "transcribe_threshold": 0.002,
    "command_timeout"     : 5,
    "language"            : "en",
    "mic_device"          : 4
},

  "startup": {
    "minimize_on_boot": [
      {
        "name": "Discord",
        "exe": "Discord.exe",
        "path": "C:\\Users\\Admin\\AppData\\Local\\Discord\\Update.exe",
        "args": [
          "--processStart Discord.exe"
        ],
        "type": "exe",
        "action": "close",
        "action_wait_time": 15,
        "launch_timeout": 5,
        "launch_interval": 2,
        "method": "shell",
        "reopen": "no"
      },
      {
        "name": "Spotify",
        "exe": "Spotify.exe",
        "path": "explorer.exe",
        "args": ["shell:appsFolder\\SpotifyAB.SpotifyMusic_zpdnekdrzrea0!Spotify"],
        "type": "exe",
        "action": "close"
      },
      {
        "name": "Steam",
        "exe": "steamwebhelper.exe",
        "path": "C:\\Program Files (x86)\\Steam\\steam.exe",
        "args": [],
        "type": "exe",
        "action": "close"
      },
      {
        "name":            "Instagram",
        "exe":             "Instagram.exe",
        "window_title":    "Instagram",
        "path":            "explorer.exe",
        "args":            ["shell:appsFolder\\Facebook.InstagramBeta_8xx8rvfyw5nnt!App"],
        "type":            "pwa",
        "action":          "close",
        "launch_timeout":  5,
        "launch_interval": 2,
        "method": "path_for_pwa"
      }
    ]
  },

  "dev_mode": {
    "default_tabs": [
      "https://github.com/error-debug-run"
    ],
    "projects": {
      "HELL": {
        "browser_tabs": [
          "https://github.com/error-debug-run/HELL",
          "https://docs.python.org/3.10/",
          "https://pypi.org"
        ],
        "trigger_apps": [
          "Code.exe",
          "pycharm64.exe",
          "GitHubDesktop.exe",
          "firefox.exe",
          "brave.exe",
          "msedge.exe"
        ]
      }
    }
  },

  "game_mode": {
    "servers": [
      "riot.com"
    ],
    "ping_threshold_warn": 100,
    "ping_threshold_bad": 200,
    "packet_loss_warn": 2,
    "trigger_apps": [
      "steam.exe",
      "EpicGamesLauncher.exe"
    ],
    "minimize_on_game": [
      "Discord",
      "Spotify",
      "Brave"
    ]
  }
}