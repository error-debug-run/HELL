<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="gui.Views.ModePickerDialog"
        Title="Assign Mode"
        Width="360"
        Height="280"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        Background="#0A0A0F">

    <StackPanel Margin="24" Spacing="16">

        <TextBlock Text="ASSIGN TO MODE"
                   Foreground="#7C3AED"
                   FontSize="11"
                   FontWeight="Bold"
                   LetterSpacing="3"/>

        <TextBlock Name="AppNameText"
                   Foreground="#E8E0FF"
                   FontSize="15"
                   FontWeight="SemiBold"/>

        <StackPanel Spacing="8" Margin="0,8,0,0">

            <Button Content="⚡  Startup Mode"
                    Click="OnStartup"
                    Background="#12101A"
                    BorderBrush="#2A1F3D"
                    BorderThickness="1"
                    Foreground="#E8E0FF"
                    Padding="16,12"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Left"
                    CornerRadius="6"/>

            <Button Content="🎮  Game Mode"
                    Click="OnGame"
                    Background="#12101A"
                    BorderBrush="#2A1F3D"
                    BorderThickness="1"
                    Foreground="#E8E0FF"
                    Padding="16,12"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Left"
                    CornerRadius="6"/>

            <Button Content="💻  Dev Mode"
                    Click="OnDev"
                    Background="#12101A"
                    BorderBrush="#2A1F3D"
                    BorderThickness="1"
                    Foreground="#E8E0FF"
                    Padding="16,12"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Left"
                    CornerRadius="6"/>

            <Button Content="✕  Cancel"
                    Click="OnCancel"
                    Background="Transparent"
                    Foreground="#6B6080"
                    Padding="16,10"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Left"
                    CornerRadius="6"/>

        </StackPanel>
    </StackPanel>
</Window>